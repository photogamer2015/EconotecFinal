# Copia este archivo como .env y reemplaza los valores con una cuenta SMTP real.
# Usa una contraseña de aplicación SMTP, no la contraseña normal del correo.

EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.tu-proveedor.com
EMAIL_PORT=587
EMAIL_HOST_USER=tu_correo@dominio.com
EMAIL_HOST_PASSWORD=tu_clave_smtp
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Econotec <tu_correo@dominio.com>
